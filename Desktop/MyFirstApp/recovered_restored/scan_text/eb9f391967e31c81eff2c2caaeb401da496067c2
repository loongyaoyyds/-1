  localStorage.setItem('todo-tasks', JSON.stringify(this.tasks));\n145\t    }\n146\t\n147\t    generateId() {\n148\t        return Date.now().toString(36) + Math.random().toString(36).substr(2);\n149\t    }\n150\t\n151\t    openModal(taskId = null) {\n152\t        const modal = document.getElementById('task-modal');\n153\t        const modalTitle = document.getElementById('modal-title');\n154\t\n155\t        if (taskId) {\n156\t            modalTitle.textContent = '编辑任务';\n157\t            this.editingTaskId = taskId;\n158\t            this.populateForm(taskId);\n159\t        } else {\n160\t            modalTitle.textContent = '添加新任务';\n161\t            this.editingTaskId = null;\n162\t            document.getElementById('task-form').reset();\n163\t        }\n164\t\n165\t        modal.style.display = 'block';\n166\t    }\n167\t\n168\t    closeModal() {\n169\t        document.getElementById('task-modal').style.display = 'none';\n170\t    }\n171\t\n172\t    populateForm(taskId) {\n173\t        const task = this.tasks.find(t => t.id === taskId);\n174\t        if (task) {\n175\t            document.getElementById('task-title').value = task.title;\n176\t            document.getElementById('task-description').value = task.description || '';\n177\t            document.getElementById('task-priority').value = task.priority;\n178\t            document.getElementById('task-category').value = task.category || '';\n179\t            document.getElementById('task-due-date').value = task.dueDate || '';\n180\t        }\n181\t    }\n182\t\n183\t    saveTask() {\n184\t        const formData = {\n185\t            title: document.getElementById('task-title').value,\n186\t            description: document.getElementById('task-description').value,\n187\t            priority: document.getElementById('task-priority').value,\n188\t            category: document.getElementById('task-category').value,\n189\t            dueDate: document.getElementById('task-due-date').value\n190\t        };\n191\t\n192\t        if (!formData.title.trim()) {\n193\t            alert('请输入任务标题');\n194\t            return;\n195\t        }\n196\t\n197\t        if (this.editingTaskId) {\n198\t            // 编辑现有任务\n199\t            const task = this.tasks.find(t => t.id === this.editingTaskId);\n200\t            if (task) {\n201\t                Object.assign(task, formData);\n202\t                task.updatedAt = new Date().toISOString();\n203\t            }\n204\t        } else {\n205\t            // 添加新任务\n206\t            const newTask = {\n207\t                id: this.generateId(),\n208\t                ...formData,\n209\t                completed: false,\n210\t                createdAt: new Date().toISOString(),\n211\t                updatedAt: new Date().toISOString()\n212\t            };\n213\t            this.tasks.push(newTask);\n214\t        }\n215\t\n216\t        this.saveTasks();\n217\t        this.closeModal();\n218\t        this.render();\n219\t        this.updateStats();\n220\t        this.setupTaskReminders(formData);\n221\t    }\n222\t\n223\t    toggleTask(taskId) {\n224\t        const task = this.tasks.find(t => t.id === taskId);\n225\t        if (task) {\n226\t            task.completed = !task.completed;\n227\t            task.updatedAt = new Date().toISOString();\n228\t            this.saveTasks();\n229\t            this.render();\n230\t            this.updateStats();\n231\t\n232\t            // Clear reminders if task is completed\n233\t            if (task.completed) {\n234\t                this.clearTaskReminders(taskId);\n235\t            } else {\n236\t                // Re-setup reminders if task is re-opened\n237\t                this.setupTaskReminders(task);\n238\t            }\n239\t        }\n240\t    }\n241\t\n242\t    editTask(taskId) {\n243\t        this.openModal(taskId);\n244\t    }\n245\t\n246\t    deleteTask(taskId) {\n247\t        if (confirm('确定要删除这个任务吗？')) {\n248\t            this.tasks = this.tasks.filter(t => t.id !== taskId);\n249\t            this.saveTasks();\n250\t            this.render();\n251\t            this.updateStats();\n252\t        }\n253\t    }\n254\t\n255\t    getFilteredAndSortedTasks() {\n256\t        let filtered = [...this.tasks];\n257\t\n258\t        // 应用筛选\n259\t        if (this.currentFilter.priority !== 'all') {\n260\t            filtered = filtered.filter(t => t.priority === this.currentFilter.priority);\n261\t        }\n262\t\n263\t        if (this.currentFilter.category !== 'all') {\n264\t            filtered = filtered.filter(t => t.category === this.currentFilter.category);\n265\t        }\n266\t\n267\t        if (this.currentFilter.status !== 'all') {\n268\t            filtered = filtered.filter(t => {\n269\t                if (this.currentFilter.status === 'completed') return t.completed;\n270\t                if (this.currentFilter.status === 'pending') return !t.completed;\n271\t                return true;\n272\t            });\n273\t        }\n274\t\n275\t        // 应用排序\n276\t        filtered.sort((a, b) => {\n277\t            switch (this.currentSort) {\n278\t                case 'date-created':\n279\t                    return new Date(b.createdAt) - new Date(a.createdAt);\n280\t                case 'due-date':\n281\t                    if (!a.dueDate) return 1;\n282\t                    if (!b.dueDate) return -1;\n283\t                    return new Date(a.dueDate) - new Date(b.dueDate);\n284\t                case 'priority':\n285\t                    const priorityOrder = { high: 3, medium: 2, low: 1 };\n286\t                    return priorityOrder[b.priority] - priorityOrder[a.priority];\n287\t                default:\n288\t                    return 0;\n289\t            }\n290\t        });\n291\t\n292\t        return filtered;\n293\t    }\n294\t\n295\t    render() {\n296\t        const taskList = document.getElementById('task-list');\n297\t        const filteredTasks = this.getFilteredAndSortedTasks();\n298\t\n299\t        // 更新分类筛选器\n300\t        this.updateCategoryFilter();\n301\t\n302\t        if (filteredTasks.length === 0) {\n303\t            taskList.innerHTML = `\n304\t                <div class=\"empty-state\">\n305\t                    <div class=\"empty-state-icon\">📝</div>\n306\t                    <h3>暂无任务</h3>\n307\t                    <p>点击\"添加新任务\"开始创建你的第一个任务吧！</p>\n308\t                </div>\n309\t            `;\n310\t            return;\n311\t        }\n312\t\n313\t        taskList.innerHTML = filteredTasks.map(task => this.renderTask(task)).join('');\n314\t\n315\t        // 绑定任务操作事件\n316\t        filteredTasks.forEach(task => {\n317\t            const taskElement = document.querySelector(`[data-task-id=\"${task.id}\"]`);\n318\t            if (taskElement) {\n319\t                taskElement.querySelector('.task-checkbox').addEventListener('change', () => {\n320\t                    this.toggleTask(task.id);\n321\t                });\n322\t\n323\t                taskElement.querySelector('.btn-edit').addEventListener('click', () => {\n324\t                    this.editTask(task.id);\n325\t                });\n326\t\n327\t                taskElement.querySelector('.btn-delete').addEventListener('click', () => {\n328\t                    this.deleteTask(task.id);\n329\t                });\n330\t            }\n331\t        });\n332\t    }\n333\t\n334\t    renderTask(task) {\n335\t        const priorityClass = `priority-${task.priority}`;\n336\t        const isOverdue = task.dueDate && !task.completed && new Date(task.dueDate) < new Date();\n337\t        const dueDateClass = isOverdue ? 'overdue' : '';\n338\t        const dueDateText = task.dueDate ? new Date(task.dueDate).toLocaleDateString('zh-CN') : '未设置';\n339\t\n340\t        return `\n341\t            <div class=\"task-item ${task.completed ? 'completed' : ''}\" data-task-id=\"${task.id}\">\n342\t                <input type=\"checkbox\" class=\"task-checkbox\" ${task.completed ? 'checked' : ''}>\n343\t                <div class=\"task-priority ${priorityClass}\"></div>\n344\t                <div class=\"task-content\">\n345\t                    <h4>${this.escapeHtml(task.title)}</h4>\n346\t                    ${task.description ? `<p class=\"task-description\">${this.escapeHtml(task.description)}</p>` : ''}\n347\t                    <div class=\"task-meta\">\n348\t                        <span class=\"task-category\">${task.category ? this.escapeHtml(task.category) : '未分类'}</span>\n349\t                        <span class=\"task-due-date ${dueDateClass}\" title=\"${isOverdue ? '已过期' : '截止日期'}\">\n350\t                            ${isOverdue ? '⚠️ ' : '📅 '}${dueDateText}\n351\t                        </span>\n352\t                    </div>\n353\t                </div>\n354\t                <div class=\"task-actions\">\n355\t                    <button class=\"btn-icon btn-edit\" title=\"编辑\">✏️</button>\n356\t                    <button class=\"btn-icon btn-delete\" title=\"删除\">🗑️</button>\n357\t                </div>\n358\t            </div>\n359\t        `;\n360\t    }\n361\t\n362\t    updateCategoryFilter() {\n363\t        const categoryFilter = document.getElementById('category-filter');\n364\t        const categories = [...new Set(this.tasks.map(t => t.category).filter(c => c))].sort();\n365\t\n366\t        // 保存当前选中的分类\n367\t        const currentCategory = this.currentFilter.category;\n368\t\n369\t        // 重新生成分类选项\n370\t        const categoryOptions = ['<option value=\"all\">全部分类</option>']\n371\t            .concat(categories.map(cat => `<option value=\"${this.escapeHtml(cat)}\">${this.escapeHtml(cat)}</option>`))\n372\t            .join('');\n373\t\n374\t        categoryFilter.innerHTML = categoryOptions;\n375\t\n376\t        // 恢复之前选中的分类\n377\t        if (categories.includes(currentCategory) || currentCategory === 'all') {\n378\t            categoryFilter.value = currentCategory;\n379\t        }\n380\t    }\n381\t\n382\t    updateStats() {\n383\t        const total = this.tasks.length;\n384\t        const completed = this.tasks.filter(t => t.completed).length;\n385\t\n386\t        document.getElementById('total-tasks').textContent = `${total} 个任务`;\n387\t        document.getElementById('completed-tasks').textContent = `${completed} 已完成`;\n388\t    }\n389\t\n390\t    escapeHtml(text) {\n391\t        const div = document.createElement('div');\n392\t        div.textContent = text;\n393\t        return div.innerHTML;\n394\t    }\n395\t\n396\t    requestNotificationPermission() {\n397\t        // Request notification permission if supported\n398\t        if ('Notification' in window) {\n399\t            Notification.requestPermission().then(permission => {\n400\t                console.log('Notification permission:', permission);\n401\t            });\n402\t        }\n403\t    }\n404\t\n405\t    checkOverdueTasks() {\n406\t        // Check for overdue tasks and send notifications\n407\t        const now = new Date();\n408\t        const today = now.toISOString().split('T')[0];\n409\t\n410\t        this.tasks.forEach(task => {\n411\t            if (task.dueDate && !task.completed) {\n412\t                const dueDate = new Date(task.dueDate);\n413\t                const todayDate = new Date(today);\n414\t\n415\t                // Check if task is overdue\n416\t                if (dueDate < todayDate) {\n417\t                    this.sendNotification(\n418\t                        '任务已过期',\n419\t                        `任务 \"${task.title}\" 已于 ${dueDate.toLocaleDateString('zh-CN')} 到期`,\n420\t                        'overdue'\n421\t                    );\n422\t                }\n423\t                // Check if task is due today\n424\t                else if (dueDate.toISOString().split('T')[0] === today) {\n425\t                    this.sendNotification(\n426\t                        '任务今天到期',\n427\t                        `任务 \"${task.title}\" 今天到期`,\n428\t                        'today'\n429\t                    );\n430\t                }\n431\t                // Check if task is due tomorrow\n432\t                else {\n433\t                    const tomorrow = new Date(today);\n434\t                    tomorrow.setDate(tomorrow.getDate() + 1);\n435\t                    if (dueDate.toISOString().split('T')[0] === tomorrow.toISOString().split('T')[0]) {\n436\t                        this.sendNotification(\n437\t                            '任务明天到期',\n438\t                            `任务 \"${task.title}\" 明天到期`,\n439\t                            'tomorrow'\n440\t                        );\n441\t                    }\n442\t                }\n443\t            }\n444\t        });\n445\t    }\n446\t\n447\t    sendNotification(title, body, type = 'info') {\n448\t        // Send desktop notification if permission granted\n449\t        if ('Notification' in window && Notification.permission === 'granted') {\n450\t            const notification = new Notification(title, {\n451\t                body: body,\n452\t                icon: '📝',\n453\t                tag: `todo-${type}`\n454\t            });\n455\t\n456\t            notification.onclick = () => {\n457\t                window.focus();\n458\t                notification.close();\n459\t            };\n460\t\n461\t            // Auto close after 5 seconds\n462\t            setTimeout(() => notification.close(), 5000);\n463\t        }\n464\t\n465\t        // Also show in-app notification\n466\t        this.showInAppNotification(title, body, type);\n467\t    }\n468\t\n469\t    showInAppNotification(title, message, type = 'info') {\n470\t        // Create notification element\n471\t        const notification = document.createElement('div');\n472\t        notification.className = `notification notification-${type}`;\n473\t        notification.innerHTML = `\n474\t            <div class=\"notification-content\">\n475\t                <strong>${this.escapeHtml(title)}</strong>\n476\t                <p>${this.escapeHtml(message)}</p>\n477\t            </div>\n478\t            <button class=\"notification-close\">&times;</button>\n479\t        `;\n480\t\n481\t        // Add to page\n482\t        document.body.appendChild(notification);\n483\t\n484\t        // Auto remove after 5 seconds\n485\t        setTimeout(() => {\n486\t            if (notification.parentNode) {\n487\t                notification.remove();\n488\t            }\n489\t        }, 5000);\n490\t\n491\t        // Close button event\n492\t        notification.querySelector('.notification-close').addEventListener('click', () => {\n493\t            notification.remove();\n494\t        });\n495\t    }\n496\t\n497\t    exportToJSON() {\n498\t        const dataStr = JSON.stringify(this.tasks, null, 2);\n499\t        const blob = new Blob([dataStr], { type: 'application/json' });\n500\t        const url = URL.createObjectURL(blob);\n501\t        const a = document.createElement('a');\n502\t        a.href = url;\n503\t        a.download = `todo-tasks-${new Date().toISOString().split('T')[0]}.json`;\n504\t        document.body.appendChild(a);\n505\t        a.click();\n506\t        document.body.removeChild(a);\n507\t        URL.revokeObjectURL(url);\n508\t\n509\t        this.showInAppNotification('导出成功', '任务数据已导出为 JSON 文件', 'success');\n510\t    }\n511\t\n512\t    exportToCSV() {\n513\t        if (this.tasks.length === 0) {\n514\t            this.showInAppNotification('导出失败', '没有任务数据可导出', 'warning');\n515\t            return;\n516\t        }\n517\t\n518\t        const headers = ['ID', '标题', '描述', '优先级', '分类', '截止日期', '完成状态', '创建时间', '更新时间'];\n519\t        const csvContent = [\n520\t            headers.join(','),\n521\t            ...this.tasks.map(task => [\n522\t                `\"${task.id}\"`,\n523\t                `\"${task.title.replace(/\"/g, '\"\"')}\"`,\n524\t                `\"${(task.description || '').replace(/\"/g, '\"\"')}\"`,\n525\t                `\"${task.priority}\"`,\n526\t                `\"${task.category || ''}\"`,\n527\t                `\"${task.dueDate || ''}\"`,\n528\t                `\"${task.completed ? '已完成' : '待完成'}\"`,\n529\t                `\"${task.createdAt}\"`,\n530\t                `\"${task.updatedAt}\"`\n531\t            ].join(','))\n532\t        ].join('\\n');\n533\t\n534\t        const blob = new Blob(['\\ufeff' + csvContent], { type: 'text/csv;charset=utf-8;' });\n535\t        const url = URL.createObjectURL(blob);\n536\t        const a = document.createElement('a');\n537\t        a.href = url;\n538\t        a.download = `todo-tasks-${new Date().toISOString().split('T')[0]}.csv`;\n539\t        document.body.appendChild(a);\n540\t        a.click();\n541\t        document.body.removeChild(a);\n542\t        URL.revokeObjectURL(url);\n543\t\n544\t        this.showInAppNotification('导出成功', '任务数据已导出为 CSV 文件', 'success');\n545\t    }\n546\t\n547\t    importData(file) {\n548\t        const reader = new FileReader();\n549\t        reader.onload = (e) => {\n550\t            try {\n551\t                const content = e.target.result;\n552\t                let importedTasks;\n553\t\n554\t                if (file.name.endsWith('.json')) {\n555\t                    importedTasks = JSON.parse(content);\n556\t                } else if (file.name.endsWith('.csv')) {\n557\t                    importedTasks = this.parseCSV(content);\n558\t                } else {\n559\t                    throw new Error('不支持的文件格式');\n560\t                }\n561\t\n562\t                // Validate imported data\n563\t                if (!Array.isArray(importedTasks)) {\n564\t                    throw new Error('导入的数据格式不正确');\n565\t                }\n566\t\n567\t                // Merge with existing tasks, avoiding duplicates\n568\t                const existingIds = new Set(this.tasks.map(t => t.id));\n569\t                let importedCount = 0;\n570\t                importedTasks.forEach(task => {\n571\t                    if (!existingIds.has(task.id)) {\n572\t                        // Ensure task has required fields\n573\t                        const validatedTask = {\n574\t                            id: task.id || this.generateId(),\n575\t                            title: task.title || '未命名任务',\n576\t                            description: task.description || '',\n577\t                            priority: task.priority || 'medium',\n578\t                            category: task.category || '',\n579\t                            dueDate: task.dueDate || '',\n580\t                            completed: task.completed || false,\n581\t                            createdAt: task.createdAt || new Date().toISOString(),\n582\t                            updatedAt: task.updatedAt || new Date().toISOString()\n583\t                        };\n584\t                        this.tasks.push(validatedTask);\n585\t                        importedCount++;\n586\t                    }\n587\t                });\n588\t\n589\t                this.saveTasks();\n590\t                this.render();\n591\t                this.updateStats();\n592\t                this.showInAppNotification('导入成功', `成功导入 ${importedCount} 个任务`, 'success');\n593\t\n594\t                // Setup reminders for imported tasks\n595\t                this.tasks.forEach(task => {\n596\t                    if (!task.completed && task.dueDate) {\n597\t                        this.setupTaskReminders(task);\n598\t                    }\n599\t                });\n600\t\n601\t            } catch (error) {\n602\t                this.showInAppNotification('导入失败', `错误: ${error.message}`, 'error');\n603\t            }\n604\t        };\n605\t        reader.readAsText(file);\n606\t    }\n607\t\n608\t    parseCSV(csvContent) {\n609\t        const lines = csvContent.split('\\n').filter(line => line.trim());\n610\t        if (lines.length < 2) return [];\n611\t\n612\t        // Skip header and BOM if present\n613\t        const startIdx = lines[0].charCodeAt(0) === 65279 ? 1 : 0;\n614\t        const headers = lines[startIdx].split(',').map(h => h.replace(/\"/g, '').trim());\n615\t        const tasks = [];\n616\t\n617\t        for (let i = startIdx + 1; i < lines.length; i++) {\n618\t            const values = this.parseCSVLine(lines[i]);\n619\t            if (values.length >= headers.length) {\n620\t                const task = {};\n621\t                headers.forEach((header, index) => {\n622\t                    let value = values[index] ? values[index].replace(/^\"|\"$/g, '') : '';\n623\t                    // Unescape double quotes\n624\t                    value = value.replace(/\"\"/g, '\"');\n625\t\n626\t                    switch (header) {\n627\t                        case 'ID':\n628\t                            task.id = value;\n629\t                            break;\n630\t                        case '标题':\n631\t                            task.title = value;\n632\t                            break;\n633\t                        case '描述':\n634\t                            task.description = value;\n635\t                            break;\n636\t                        case '优先级':\n637\t                            task.priority = value.toLowerCase() || 'medium';\n638\t                            break;\n639\t                        case '分类':\n640\t                            task.category = value;\n641\t                            break;\n642\t                        case '截止日期':\n643\t                            task.dueDate = value;\n644\t                            break;\n645\t                        case '完成状态':\n646\t                            task.completed = value === '已完成';\n647\t                            break;\n648\t                        case '创建时间':\n649\t                            task.createdAt = value || new Date().toISOString();\n650\t                            break;\n651\t                        case '更新时间':\n652\t                            task.updatedAt = value || new Date().toISOString();\n653\t                            break;\n654\t                    }\n655\t                });\n656\t                tasks.push(task);\n657\t            }\n658\t        }\n659\t\n660\t        return tasks;\n661\t    }\n662\t\n663\t    parseCSVLine(line) {\n664\t        const values = [];\n665\t        let current = '';\n666\t        let inQuotes = false;\n667\t\n668\t        for (let i = 0; i < line.length; i++) {\n669\t            const char = line[i];\n670\t\n671\t            if (char === '\"') {\n672\t                if (inQuotes && i + 1 < line.length && line[i + 1] === '\"') {\n673\t                    // Double quote inside quotes\n674\t                    current += '\"';\n675\t                    i++; // Skip next quote\n676\t                } else {\n677\t                    inQuotes = !inQuotes;\n678\t                }\n679\t            } else if (char === ',' && !inQuotes) {\n680\t                values.push(current.trim());\n681\t                current = '';\n682\t            } else {\n683\t                current += char;\n684\t            }\n685\t        }\n686\t\n687\t        values.push(current.trim());\n688\t        return values;\n689\t    }\n690\t\n691\t    backupData() {\n692\t        const backup = {\n693\t            tasks: this.tasks,\n694\t            backupDate: new Date().toISOString(),\n695\t            version: '1.0'\n696\t        };\n697\t\n698\t        const dataStr = JSON.stringify(backup, null, 2);\n699\t        const blob = new Blob([dataStr], { type: 'application/json' });\n700\t        const url = URL.createObjectURL(blob);\n701\t        const a = document.createElement('a');\n702\t        a.href = url;\n703\t        a.download = `todo-backup-${new Date().toISOString().split('T')[0]}.json`;\n704\t        document.body.appendChild(a);\n705\t        a.click();\n706\t        document.body.removeChild(a);\n707\t        URL.revokeObjectURL(url);\n708\t\n709\t        this.showInAppNotification('备份成功', '数据已备份到本地文件', 'success');\n710\t    }\n711\t\n712\t    restoreData(file) {\n713\t        const reader = new FileReader();\n714\t        reader.onload = (e) => {\n715\t            try {\n716\t                const content = e.target.result;\n717\t                let backup;\n718\t\n719\t                backup = JSON.parse(content);\n720\t                if (!backup.tasks || !Array.isArray(backup.tasks)) {\n721\t                    throw new Error('备份文件格式不正确');\n722\t                }\n723\t                this.tasks = backup.tasks;\n724\t\n725\t                this.saveTasks();\n726\t                this.render();\n727\t                this.updateStats();\n728\t                this.showInAppNotification('恢复成功', '数据已从备份恢复', 'success');\n729\t\n730\t            } catch (error) {\n731\t                this.showInAppNotification('恢复失败', `错误: ${error.message}`, 'error');\n732\t            }\n733\t        };\n734\t        reader.readAsText(file);\n735\t    }\n736\t\n737\t    setupTaskReminders(task) {\n738\t        // Clear existing reminders for this task\n739\t        this.clearTaskReminders(task.id);\n740\t\n741\t        // Don't set reminders if no due date or already completed\n742\t        if (!task.dueDate || task.completed) {\n743\t            return;\n744\t        }\n745\t\n746\t        const dueDate = new Date(task.dueDate);\n747\t        const now = new Date();\n748\t        const timeUntilDue = dueDate - now;\n749\t\n750\t        // Only set reminders if due date is in the future\n751\t        if (timeUntilDue <= 0) {\n752\t            return;\n753\t        }\n754\t\n755\t        // Set reminder at 1 day before\n756\t        const oneDayBefore = timeUntilDue - (24 * 60 * 60 * 1000);\n757\t        if (oneDayBefore > 0) {\n758\t            const reminderId = setTimeout(() => {\n759\t                this.sendNotification(\n760\t                    '任务即将到期',\n761\t                    `任务 \"${task.title}\" 将于明天到期`,\n762\t                    'reminder'\n763\t                );\n764\t            }, oneDayBefore);\n765\t            this.reminderIntervals.push({ taskId: task.id, intervalId: reminderId });\n766\t        }\n767\t\n768\t        // Set reminder at 1 hour before\n769\t        const oneHourBefore = timeUntilDue - (60 * 60 * 1000);\n770\t        if (oneHourBefore > 0) {\n771\t            const reminderId = setTimeout(() => {\n772\t                this.sendNotification(\n773\t                    '任务即将到期',\n774\t                    `任务 \"${task.title}\" 将于1小时后到期`,\n775\t                    'reminder'\n776\t                );\n777\t            }, oneHourBefore);\n778\t            this.reminderIntervals.push({ taskId: task.id, intervalId: reminderId });\n779\t        }\n780\t\n781\t        // Set reminder at due time\n782\t        const reminderId = setTimeout(() => {\n783\t            this.sendNotification(\n784\t                '任务已到期',\n785\t                `任务 \"${task.title}\" 现在已到期`,\n786\t                'overdue'\n787\t            );\n788\t        }, timeUntilDue);\n789\t        this.reminderIntervals.push({ taskId: task.id, intervalId: reminderId });\n790\t    }\n791\t\n792\t    clearTaskReminders(taskId) {\n793\t        // Clear all reminders for a specific task\n794\t        this.reminderIntervals = this.reminderIntervals.filter(reminder => {\n795\t            if (reminder.taskId === taskId) {\n796\t                clearTimeout(reminder.intervalId);\n797\t                return false;\n798\t            }\n799\t            return true;\n800\t        });\n801\t    }\n802\t}\n803\t\n804\t// 应用初始化\n805\tdocument.addEventListener('DOMContentLoaded', () => {\n806\t    new TodoApp();\n807\t});"}]},"uuid":"72f4d1bd-7a16-486a-abd0-8fffecd1d610","timestamp":"2026-04-17T17:37:07.120Z","toolUseResult":{"type":"text","file":{"filePath":"/Users/loongyao/todo-app.js","content":"class TodoApp {\n    constructor() {\n        this.tasks = this.loadTasks();\n        this.currentFilter = {\n            priority: 'all',\n            category: 'all',\n            status: 'all'\n        };\n        this.currentSort = 'date-created';\n        this.editingTaskId = null;\n        this.reminderIntervals = [];\n\n        // Cloud sync settings\n        this.cloudSyncEnabled = false;\n        this.supabase = null;\n\n        this.init();\n    }\n\n    init() {\n        this.bindEvents();\n        this.render();\n        this.updateStats();\n        this.requestNotificationPermission();\n        this.checkOverdueTasks();\n    }\n\n    bindEvents() {\n        // 添加任务按钮\n        document.getElementById('add-task-btn').addEventListener('click', () => {\n            this.openModal();\n        });\n\n        // 模态框相关事件\n        const modal = document.getElementById('task-modal');\n        const closeBtn = document.querySelector('.close');\n        const cancelBtn = document.getElementById('cancel-btn');\n        const taskForm = document.getElementById('task-form');\n\n        closeBtn.addEventListener('click', () => this.closeModal());\n        cancelBtn.addEventListener('click', () => this.closeModal());\n        modal.addEventListener('click', (e) => {\n            if (e.target === modal) this.closeModal();\n        });\n\n        taskForm.addEventListener('submit', (e) => {\n            e.preventDefault();\n            this.saveTask();\n        });\n\n        // 筛选器事件\n        document.getElementById('priority-filter').addEventListener('change', (e) => {\n            this.currentFilter.priority = e.target.value;\n            this.render();\n        });\n\n        document.getElementById('category-filter').addEventListener('change', (e) => {\n            this.currentFilter.category = e.target.value;\n            this.render();\n        });\n\n        document.getElementById('status-filter').addEventListener('change', (e) => {\n            this.currentFilter.status = e.target.value;\n            this.render();\n        });\n\n        // 排序事件\n        document.getElementById('sort-by').addEventListener('change', (e) => {\n            this.currentSort = e.target.value;\n            this.render();\n        });\n\n        // Add data management buttons\n        this.addDataManagementButtons();\n\n        // Add theme toggle button\n        this.addThemeToggleButton();\n\n        // Add search functionality\n        this.addSearchFunctionality();\n\n        // Setup keyboard shortcuts\n        this.setupKeyboardShortcuts();\n    }\n\n    addDataManagementButtons() {\n        // Add export/import buttons to the sidebar\n        const sidebar = document.querySelector('.sidebar');\n        const existingSection = sidebar.querySelector('.add-task-section');\n\n        // Create data management section\n        const dataSection = document.createElement('div');\n        dataSection.className = 'data-management-section';\n        dataSection.innerHTML = `\n            <h3>数据管理</h3>\n            <div class=\"data-actions\">\n                <button id=\"export-json\" class=\"btn-data\">导出 JSON</button>\n                <button id=\"export-csv\" class=\"btn-data\">导出 CSV</button>\n                <button id=\"import-data\" class=\"btn-data\">导入数据</button>\n                <button id=\"backup-data\" class=\"btn-data\">备份数据</button>\n                <button id=\"restore-data\" class=\"btn-data\">恢复数据</button>\n            </div>\n            <input type=\"file\" id=\"file-input\" style=\"display: none;\" accept=\".json,.csv\">\n        `;\n\n        // Insert after add task section\n        existingSection.parentNode.insertBefore(dataSection, existingSection.nextSibling);\n\n        // Bind events\n        document.getElementById('export-json').addEventListener('click', () => this.exportToJSON());\n        document.getElementById('export-csv').addEventListener('click', () => this.exportToCSV());\n        document.getElementById('import-data').addEventListener('click', () => {\n            document.getElementById('file-input').click();\n        });\n        document.getElementById('backup-data').addEventListener('click', () => this.backupData());\n        document.getElementById('restore-data').addEventListener('click', () => {\n            if (confirm('确定要恢复备份吗？这将覆盖当前所有数据。')) {\n                document.getElementById('file-input').click();\n            }\n        });\n\n        // File input change event\n        document.getElementById('file-input').addEventListener('change', (e) => {\n            const file = e.target.files[0];\n            if (file) {\n                // Check if it's a backup file\n                if (file.name.includes('backup')) {\n                    this.restoreData(file);\n                } else {\n                    this.importData(file);\n                }\n            }\n            // Reset file input\n            e.target.value = '';\n        });\n    }\n\n    loadTasks() {\n        const saved = localStorage.getItem('todo-tasks');\n        return saved ? JSON.parse(saved) : [];\n    }\n\n    saveTasks() {\n        localStorage.setItem('todo-tasks', JSON.stringify(this.tasks));\n    }\n\n    generateId() {\n        return Date.now().toString(36) + Math.random().toString(36).substr(2);\n    }\n\n    openModal(taskId = null) {\n        const modal = document.getElementById('task-modal');\n        const modalTitle = document.getElementById('modal-title');\n\n        if (taskId) {\n            modalTitle.textContent = '编辑任务';\n            this.editingTaskId = taskId;\n            this.populateForm(taskId);\n        } else {\n            modalTitle.textContent = '添加新任务';\n            this.editingTaskId = null;\n            document.getElementById('task-form').reset();\n        }\n\n        modal.style.display = 'block';\n    }\n\n    closeModal() {\n        document.getElementById('task-modal').style.display = 'none';\n    }\n\n    populateForm(taskId) {\n        const task = this.tasks.find(t => t.id === taskId);\n        if (task) {\n            document.getElementById('task-title').value = task.title;\n            document.getElementById('task-description').value = task.description || '';\n            document.getElementById('task-priority').value = task.priority;\n            document.getElementById('task-category').value = task.category || '';\n            document.getElementById('task-due-date').value = task.dueDate || '';\n        }\n    }\n\n    saveTask() {\n        const formData = {\n            title: document.getElementById('task-title').value,\n            description: document.getElementById('task-description').value,\n            priority: document.getElementById('task-priority').value,\n            category: document.getElementById('task-category').value,\n            dueDate: document.getElementById('task-due-date').value\n        };\n\n        if (!formData.title.trim()) {\n            alert('请输入任务标题');\n            return;\n        }\n\n        if (this.editingTaskId) {\n            // 编辑现有任务\n            const task = this.tasks.find(t => t.id === this.editingTaskId);\n            if (task) {\n                Object.assign(task, formData);\n                task.updatedAt = new Date().toISOString();\n            }\n        } else {\n            // 添加新任务\n            const newTask = {\n                id: this.generateId(),\n                ...formData,\n                completed: false,\n                createdAt: new Date().toISOString(),\n                updatedAt: new Date().toISOString()\n            };\n            this.tasks.push(newTask);\n        }\n\n        this.saveTasks();\n        this.closeModal();\n        this.render();\n        this.updateStats();\n        this.setupTaskReminders(formData);\n    }\n\n    toggleTask(taskId) {\n        const task = this.tasks.find(t => t.id === taskId);\n        if (task) {\n            task.completed = !task.completed;\n            task.updatedAt = new Date().toISOString();\n            this.saveTasks();\n            this.render();\n            this.updateStats();\n\n            // Clear reminders if task is completed\n            if (task.completed) {\n                this.clearTaskReminders(taskId);\n            } else {\n                // Re-setup reminders if task is re-opened\n                this.setupTaskReminders(task);\n            }\n        }\n    }\n\n    editTask(taskId) {\n        this.openModal(taskId);\n    }\n\n    deleteTask(taskId) {\n        if (confirm('确定要删除这个任务吗？')) {\n            this.tasks = this.tasks.filter(t => t.id !== taskId);\n            this.saveTasks();\n            this.render();\n            this.updateStats();\n        }\n    }\n\n    getFilteredAndSortedTasks() {\n        let filtered = [...this.tasks];\n\n        // 应用筛选\n        if (this.currentFilter.priority !== 'all') {\n            filtered = filtered.filter(t => t.priority === this.currentFilter.priority);\n        }\n\n        if (this.currentFilter.category !== 'all') {\n            filtered = filtered.filter(t => t.category === this.currentFilter.category);\n        }\n\n        if (this.currentFilter.status !== 'all') {\n            filtered = filtered.filter(t => {\n                if (this.currentFilter.status === 'completed') return t.completed;\n                if (this.currentFilter.status === 'pending') return !t.completed;\n                return true;\n            });\n        }\n\n        // 应用排序\n        filtered.sort((a, b) => {\n            switch (this.currentSort) {\n                case 'date-created':\n                    return new Date(b.createdAt) - new Date(a.createdAt);\n                case 'due-date':\n                    if (!a.dueDate) return 1;\n                    if (!b.dueDate) return -1;\n                    return new Date(a.dueDate) - new Date(b.dueDate);\n                case 'priority':\n                    const priorityOrder = { high: 3, medium: 2, low: 1 };\n                    return priorityOrder[b.priority] - priorityOrder[a.priority];\n                default:\n                    return 0;\n            }\n        });\n\n        return filtered;\n    }\n\n    render() {\n        const taskList = document.getElementById('task-list');\n        const filteredTasks = this.getFilteredAndSortedTasks();\n\n        // 更新分类筛选器\n        this.updateCategoryFilter();\n\n        if (filteredTasks.length === 0) {\n            taskList.innerHTML = `\n                <div class=\"empty-state\">\n                    <div class=\"empty-state-icon\">📝</div>\n                    <h3>暂无任务</h3>\n                    <p>点击\"添加新任务\"开始创建你的第一个任务吧！</p>\n                </div>\n            `;\n            return;\n        }\n\n        taskList.innerHTML = filteredTasks.map(task => this.renderTask(task)).join('');\n\n        // 绑定任务操作事件\n        filteredTasks.forEach(task => {\n            const taskElement = document.querySelector(`[data-task-id=\"${task.id}\"]`);\n            if (taskElement) {\n                taskElement.querySelector('.task-checkbox').addEventListener('change', () => {\n                    this.toggleTask(task.id);\n                });\n\n                taskElement.querySelector('.btn-edit').addEventListener('click', () => {\n                    this.editTask(task.id);\n                });\n\n                taskElement.querySelector('.btn-delete').addEventListener('click', () => {\n                    this.deleteTask(task.id);\n                });\n            }\n        });\n    }\n\n    renderTask(task) {\n        const priorityClass = `priority-${task.priority}`;\n        const isOverdue = task.dueDate && !task.completed && new Date(task.dueDate) < new Date();\n        const dueDateClass = isOverdue ? 'overdue' : '';\n        const dueDateText = task.dueDate ? new Date(task.dueDate).toLocaleDateString('zh-CN') : '未设置';\n\n        return `\n            <div class=\"task-item ${task.completed ? 'completed' : ''}\" data-task-id=\"${task.id}\">\n                <input type=\"checkbox\" class=\"task-checkbox\" ${task.completed ? 'checked' : ''}>\n                <div class=\"task-priority ${priorityClass}\"></div>\n                <div class=\"task-content\">\n                    <h4>${this.escapeHtml(task.title)}</h4>\n                    ${task.description ? `<p class=\"task-description\">${this.escapeHtml(task.description)}</p>` : ''}\n                    <div class=\"task-meta\">\n                        <span class=\"task-category\">${task.category ? this.escapeHtml(task.category) : '未分类'}</span>\n                        <span class=\"task-due-date ${dueDateClass}\" title=\"${isOverdue ? '已过期' : '截止日期'}\">\n                            ${isOverdue ? '⚠️ ' : '📅 '}${dueDateText}\n                        </span>\n                    </div>\n                </div>\n                <div class=\"task-actions\">\n                    <button class=\"btn-icon btn-edit\" title=\"编辑\">✏️</button>\n                    <button class=\"btn-icon btn-delete\" title=\"删除\">🗑️</button>\n                </div>\n            </div>\n        `;\n    }\n\n    updateCategoryFilter() {\n        const categoryFilter = document.getElementById('category-filter');\n        const categories = [...new Set(this.tasks.map(t => t.category).filter(c => c))].sort();\n\n        // 保存当前选中的分类\n        const currentCategory = this.currentFilter.category;\n\n        // 重新生成分类选项\n        const categoryOptions = ['<option value=\"all\">全部分类</option>']\n            .concat(categories.map(cat => `<option value=\"${this.escapeHtml(cat)}\">${this.escapeHtml(cat)}</option>`))\n            .join('');\n\n        categoryFilter.innerHTML = categoryOptions;\n\n        // 恢复之前选中的分类\n        if (categories.includes(currentCategory) || currentCategory === 'all') {\n            categoryFilter.value = currentCategory;\n        }\n    }\n\n    updateStats() {\n        const total = this.tasks.length;\n        const completed = this.tasks.filter(t => t.completed).length;\n\n        document.getElementById('total-tasks').textContent = `${total} 个任务`;\n        document.getElementById('completed-tasks').textContent = `${completed} 已完成`;\n    }\n\n    escapeHtml(text) {\n        const div = document.createElement('div');\n        div.textContent = text;\n        return div.innerHTML;\n    }\n\n    requestNotificationPermission() {\n        // Request notification permission if supported\n        if ('Notification' in window) {\n            Notification.requestPermission().then(permission => {\n                console.log('Notification permission:', permission);\n            });\n        }\n    }\n\n    checkOverdueTasks() {\n        // Check for overdue tasks and send notifications\n        const now = new Date();\n        const today = now.toISOString().split('T')[0];\n\n        this.tasks.forEach(task => {\n            if (task.dueDate && !task.completed) {\n                const dueDate = new Date(task.dueDate);\n                const todayDate = new Date(today);\n\n                // Check if task is overdue\n                if (dueDate < todayDate) {\n                    this.sendNotification(\n                        '任务已过期',\n                        `任务 \"${task.title}\" 已于 ${dueDate.toLocaleDateString('zh-CN')} 到期`,\n                        'overdue'\n                    );\n                }\n                // Check if task is due today\n                else if (dueDate.toISOString().split('T')[0] === today) {\n                    this.sendNotification(\n                        '任务今天到期',\n                        `任务 \"${task.title}\" 今天到期`,\n                        'today'\n                    );\n                }\n                // Check if task is due tomorrow\n                else {\n                    const tomorrow = new Date(today);\n                    tomorrow.setDate(tomorrow.getDate() + 1);\n                    if (dueDate.toISOString().split('T')[0] === tomorrow.toISOString().split('T')[0]) {\n                        this.sendNotification(\n                            '任务明天到期',\n                            `任务 \"${task.title}\" 明天到期`,\n                            'tomorrow'\n                        );\n                    }\n                }\n            }\n        });\n    }\n\n    sendNotification(title, body, type = 'info') {\n        // Send desktop notification if permission granted\n        if ('Notification' in window && Notification.permission === 'granted') {\n            const notification = new Notification(title, {\n                body: body,\n                icon: '📝',\n                tag: `todo-${type}`\n            });\n\n            notification.onclick = () => {\n                window.focus();\n                notification.close();\n            };\n\n            // Auto close after 5 seconds\n            setTimeout(() => notification.close(), 5000);\n        }\n\n        // Also show in-app notification\n        this.showInAppNotification(title, body, type);\n    }\n\n    showInAppNotification(title, message, type = 'info') {\n        // Create notification element\n        const notification = document.createElement('div');\n        notification.className = `notification notification-${type}`;\n        notification.innerHTML = `\n            <div class=\"notification-content\">\n                <strong>${this.escapeHtml(title)}</strong>\n                <p>${this.escapeHtml(message)}</p>\n            </div>\n            <button class=\"notification-close\">&times;</button>\n        `;\n\n        // Add to page\n        document.body.appendChild(notification);\n\n        // Auto remove after 5 seconds\n        setTimeout(() => {\n            if (notification.parentNode) {\n                notification.remove();\n            }\n        }, 5000);\n\n        // Close button event\n        notification.querySelector('.notification-close').addEventListener('click', () => {\n            notification.remove();\n        });\n    }\n\n    exportToJSON() {\n        const dataStr = JSON.stringify(this.tasks, null, 2);\n        const blob = new Blob([dataStr], { type: 'application/json' });\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url;\n        a.download 