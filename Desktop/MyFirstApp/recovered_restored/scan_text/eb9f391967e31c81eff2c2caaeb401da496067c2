nder();\n53\t        });\n54\t\n55\t        document.getElementById('status-filter').addEventListener('change', (e) => {\n56\t            this.currentFilter.status = e.target.value;\n57\t            this.render();\n58\t        });\n59\t\n60\t        // 排序事件\n61\t        document.getElementById('sort-by').addEventListener('change', (e) => {\n62\t            this.currentSort = e.target.value;\n63\t            this.render();\n64\t        });\n65\t    }\n66\t\n67\t    loadTasks() {\n68\t        const saved = localStorage.getItem('todo-tasks');\n69\t        return saved ? JSON.parse(saved) : [];\n70\t    }\n71\t\n72\t    saveTasks() {\n73\t        localStorage.setItem('todo-tasks', JSON.stringify(this.tasks));\n74\t    }\n75\t\n76\t    generateId() {\n77\t        return Date.now().toString(36) + Math.random().toString(36).substr(2);\n78\t    }\n79\t\n80\t    openModal(taskId = null) {\n81\t        const modal = document.getElementById('task-modal');\n82\t        const modalTitle = document.getElementById('modal-title');\n83\t\n84\t        if (taskId) {\n85\t            modalTitle.textContent = '编辑任务';\n86\t            this.editingTaskId = taskId;\n87\t            this.populateForm(taskId);\n88\t        } else {\n89\t            modalTitle.textContent = '添加新任务';\n90\t            this.editingTaskId = null;\n91\t            document.getElementById('task-form').reset();\n92\t        }\n93\t\n94\t        modal.style.display = 'block';\n95\t    }\n96\t\n97\t    closeModal() {\n98\t        document.getElementById('task-modal').style.display = 'none';\n99\t    }\n100\t\n101\t    populateForm(taskId) {\n102\t        const task = this.tasks.find(t => t.id === taskId);\n103\t        if (task) {\n104\t            document.getElementById('task-title').value = task.title;\n105\t            document.getElementById('task-description').value = task.description || '';\n106\t            document.getElementById('task-priority').value = task.priority;\n107\t            document.getElementByI