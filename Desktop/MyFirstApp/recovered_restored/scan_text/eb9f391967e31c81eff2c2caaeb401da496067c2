sion();\n            \n            // Setup auth listeners\n            this.setupAuthListeners();\n        };\n        document.head.appendChild(script);\n    }\n\n    checkExistingSession() {\n        if (this.supabase) {\n            this.supabase.auth.getSession().then(({ data: { session } }) => {\n                if (session?.user) {\n                    this.currentUser = session.user;\n                    this.showInAppNotification('云端同步', '已连接到云端账户', 'success');\n                    this.syncFromCloud();\n                }\n            });\n        }\n    }\n\n    setupAuthListeners() {\n        if (this.supabase) {\n            this.supabase.auth.onAuthStateChange((event, session) => {\n                if (event === 'SIGNED_IN' && session?.user) {\n                    this.currentUser = session.user;\n                    this.showInAppNotification('云端同步', '已登录云端账户', 'success');\n                    this.syncFromCloud();\n                } else if (event === 'SIGNED_OUT') {\n                    this.currentUser = null;\n                    this.showInAppNotification('云端同步', '已退出云端账户', 'info');\n                }\n            });\n        }\n    }\n\n    async syncToCloud() {\n        if (!this.cloudSyncEnabled || !this.currentUser) {\n            return;\n        }\n\n        try {\n            const { data, error } = await this.supabase\n                .from('tasks')\n                .upsert({\n                    user_id: this.currentUser.id,\n                    tasks: this.tasks,\n                    updated_at: new Date().toISOString()\n                }, {\n                    onConflict: 'user_id'\n                });\n\n            if (error) {\n                console.error('Sync to cloud error:', error);\n                this.showInAppNotification('云端同步', '同步失败: ' + error.message, 'error');\n            } else {\n                console.log('Synced to cloud successfully');\n                this.showInAppNotification('云端同步', '数据已同步到云端', 'success');