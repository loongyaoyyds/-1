e: '还有1小时' }       // 提前1小时\n        ];\n\n        reminders.forEach(reminder => {\n            const reminderTime = timeDiff - reminder.time;\n            if (reminderTime > 0) {\n                const timeoutId = setTimeout(() => {\n                    this.sendNotification(`任务提醒: ${task.title}`, {\n                        body: `${reminder.message}截止: ${task.title}`,\n                        tag: `task-reminder-${task.id}`\n                    });\n                }, reminderTime);\n\n                this.reminderIntervals.push({ taskId: task.id, timeoutId, type: reminder.message });\n            }\n        });\n\n        // 如果是今天截止，添加一个\"今天截止\"的提醒\n        const today = new Date().toDateString();\n        const dueDateStr = dueDate.toDateString();\n        if (dueDateStr === today && timeDiff > 0) {\n            const timeoutId = setTimeout(() => {\n                this.sendNotification(`今日截止: ${task.title}`, {\n                    body: `这个任务今天截止，请尽快完成！`,\n                    tag: `task-due-today-${task.id}`\n                });\n            }, Math.max(timeDiff - 2 * 60 * 60 * 1000, 0)); // 提前2小时\n\n            this.reminderIntervals.push({ taskId: task.id, timeoutId, type: 'today-reminder' });\n        }\n    }\n\n    // 取消任务提醒\n    cancelTaskReminders(taskId) {\n        this.reminderIntervals\n            .filter(r => r.taskId === taskId)\n            .forEach(r => clearTimeout(r.timeoutId));\n        \n        this.reminderIntervals = this.reminderIntervals.filter(r => r.taskId !== taskId);\n    }\n\n    // 清除所有提醒\n    clearAllReminders() {\n        this.reminderIntervals.forEach(r => clearTimeout(r.timeoutId));\n        this.reminderIntervals = [];\n    }\n\n    // 重新安排所有任务的提醒\n    rescheduleAllReminders(tasks) {\n        this.clearAllReminders();\n        tasks.forEach(task => this.scheduleTaskReminder(task));\n    }\n\n    // 发送每日摘要\n    async sendDailySummary(tasks) {\n        const pendingTasks = tasks.filter(t => !t.completed);\n        const completedTasks = tasks.filter(t => t.completed);\n        \n        const today = new Date().toLocaleDateString('zh-CN');\n        const summary = `📊 ${today} 任务摘要\\n\\n待完成任务: ${pendingTasks.length}个\\n已完成任务: ${completedTasks.length}个\\n完成率: ${tasks.length > 0 ? Math.round((completedTasks.length / tasks.length) * 100) : 0}%`;\n\n        await this.sendNotification('每日任务摘要', {\n            body: summary,\n            tag: 'daily-summary'\n        });\n    }\n\n    // 安排每日摘要（每天早上9点）\n    scheduleDailySummary(tasks) {\n        const now = new Date();\n        const targetTime = new Date();\n        targetTime.setHours(9, 0, 0, 0); // 每天早上9点\n\n        // 如果今天已经过了9点，安排明天\n        if (now > targetTime) {\n            targetTime.setDate(targetTime.getDate() + 1);\n        }\n\n        const timeDiff = targetTime.getTime() - now.getTime();\n        \n        setTimeout(() => {\n            this.sendDailySummary(tasks);\n            // 设置重复（24小时后再次执行）\n            setInterval(() => {\n                this.sendDailySummary(tasks);\n            }, 24 * 60 * 60 * 1000);\n        }, timeDiff);\n    }\n}</longcat_arg_value>\n</longcat_tool_call>\n","signature":""}],"stop_reason":"end_turn","stop_sequence":null,"usage":{"input_tokens":32448,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":1189,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"}},"type":"assistant","uuid":"9f61ee41-4954-49e8-bef4-cbcef4feb6f1","timestamp":"2026-04-17T05:54:08.335Z","userType":"external","entrypoint":"claude-vscode","cwd":"/Users/loongyao","sessionId":"70abcc24-236b-4ffe-b500-728c9a8e6f7e","version":"2.1.109","gitBranch":"HEAD","slug":"cosmic-crunching-hamster"}
