e(resolve => setTimeout(resolve, 1500));\n\n            // Save to localStorage as cloud backup\n            const cloudData = {\n                tasks: this.tasks,\n                userId: this.currentUser.id,\n                lastSync: new Date().toISOString(),\n                version: '1.0'\n            };\n\n            localStorage.setItem('cloud-backup-' + this.currentUser.id, JSON.stringify(cloudData));\n            this.lastSyncTime = new Date().toISOString();\n\n            this.showInAppNotification('云端同步', '数据同步成功', 'success');\n            document.getElementById('cloud-status').textContent = '已同步';\n            document.getElementById('cloud-sync').textContent = '🔄 同步';\n        } catch (error) {\n            this.showInAppNotification('云端同步', '同步失败: ' + error.message, 'error');\n            document.getElementById('cloud-status').textContent = '同步失败';\n        } finally {\n            this.syncInProgress = false;\n        }\n    }\n\n    async syncFromCloud() {\n        if (!this.currentUser) {\n            return;\n        }\n\n        // Check for cloud backup in localStorage\n        const cloudData = localStorage.getItem('cloud-backup-' + this.currentUser.id);\n        if (cloudData) {\n            try {\n                const data = JSON.parse(cloudData);\n                if (data.tasks && Array.isArray(data.tasks)) {\n                    // Merge with local tasks\n                    const existingIds = new Set(this.tasks.map(t => t.id));\n                    const newTasks = data.tasks.filter(t => !existingIds.has(t.id));\n                    this.tasks = [...this.tasks, ...newTasks];\n\n                    this.saveTasks();\n                    this.render();\n                    this.updateStats();\n\n                    this.showInAppNotification('云端同步', '云端数据加载成功', 'success');\n                }\n            } catch (error) {\n                console.error('Failed to load cloud data:', error);\n            }\n        }\n\n        document.g